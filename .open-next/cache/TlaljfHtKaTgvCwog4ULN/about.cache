ss=\"group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-all duration-150 text-gray-600 hover:bg-gray-50 hover:text-gray-800 \" href=\"/messages\"><span class=\"shrink-0\"><svg class=\"w-5 h-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.525C3.373 3.748 2.25 5.14 2.25 6.741v6.018z\"></path></svg></span><span class=\"text-sm\">Inbox</span></a></div><div class=\"relative\"><a class=\"group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-all duration-150 text-gray-600 hover:bg-gray-50 hover:text-gray-800 \" href=\"/notifications\"><span class=\"shrink-0\"><svg class=\"w-5 h-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0\"></path></svg></span><span class=\"text-sm\">Updates</span><span class=\"ml-auto bg-red-500 text-white text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center\">2</span></a></div></nav><div class=\"border-t border-gray-200 py-2 px-2 space-y-0.5\"><div class=\"relative px-3 py-1.5\"><button class=\"flex items-center gap-2 text-xs text-gray-500 hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 rounded-lg px-2 py-1.5 w-full transition-all duration-150\"><svg class=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9\"></path></svg>Demo<svg class=\"w-3 h-3 ml-auto transition-transform duration-150 \" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19 9l-7 7-7-7\"></path></svg></button></div><button class=\"flex items-center justify-center w-full py-1.5 text-gray-400 hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 rounded-lg transition-all duration-150 group\" title=\"Collapse\"><svg class=\"w-4 h-4 transition-all duration-300 group-hover:-translate-x-0.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M15.75 19.5L8.25 12l7.5-7.5\"></path></svg></button></div></aside><div class=\"flex-1 flex flex-col min-w-0\"><div class=\"hidden lg:flex items-center h-12 px-6 bg-white border-b border-gray-200\"><nav class=\"flex items-center gap-2 flex-1\"><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/?type=buy\">Buy</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/?type=rent\">Rent</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/sell\">Sell</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/agent\">Manage Rentals</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/list-property\">Advertise</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-[var(--color-primary)] bg-[var(--color-primary)]/5\" href=\"/about\">About</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/contact\">Contact</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/help\">Get Help</a></nav><div class=\"flex items-center gap-2\"><a class=\"text-xs text-white bg-[var(--color-primary)] px-3 py-1.5 rounded-md hover:bg-[var(--color-primary-light)] transition-colors\" href=\"/login\">Sign In</a></div></div><main class=\"flex-1 overflow-y-auto pb-16 lg:pb-0\"><div class=\"flex-1\"><section class=\"relative bg-[var(--color-primary)] py-24 px-4 overflow-hidden\"><div class=\"absolute inset-0 bg-[url(&#x27;https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=1200&amp;h=600&amp;fit=crop&#x27;)] bg-cover bg-center opacity-10\"></div><div class=\"relative max-w-3xl mx-auto text-center\"><span class=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/10 text-white/90 text-xs font-medium mb-6\">About MBPP</span><h1 class=\"text-4xl md:text-5xl font-bold text-white leading-tight\">Making Real Estate <span class=\"text-[var(--color-accent)]\">Simple &amp; Accessible</span></h1><p class=\"mt-4 text-lg text-white/70 max-w-2xl mx-auto\">We are on a mission to transform real estate in Northern Nigeria through technology, transparency, and local expertise.</p></div></section><section class=\"max-w-5xl mx-auto px-4 -mt-10 relative z-10\"><div class=\"bg-white rounded-lg border border-gray-200 p-8 shadow-lg grid grid-cols-2 md:grid-cols-4 gap-8\"><div class=\"text-center\"><p class=\"text-2xl md:text-3xl font-bold text-[var(--color-primary)]\">20+</p><p class=\"text-xs text-gray-500 mt-1\">Verified Listings</p></div><div class=\"text-center\"><p class=\"text-2xl md:text-3xl font-bold text-[var(--color-primary)]\">4</p><p class=\"text-xs text-gray-500 mt-1\">Cities Covered</p></div><div class=\"text-center\"><p class=\"text-2xl md:text-3xl font-bold text-[var(--color-primary)]\">10+</p><p class=\"text-xs text-gray-500 mt-1\">Agents &amp; Staff</p></div><div class=\"text-center\"><p class=\"text-2xl md:text-3xl font-bold text-[var(--color-primary)]\">₦14M+</p><p class=\"text-xs text-gray-500 mt-1\">Revenue Generated</p></div></div></section><section class=\"max-w-5xl mx-auto px-4 py-16\"><div class=\"grid md:grid-cols-2 gap-12 items-center mb-20\"><div><span class=\"text-xs font-medium text-[var(--color-primary)] uppercase tracking-wider\">Why MBPP</span><h2 class=\"text-2xl font-bold text-gray-900 mt-2 mb-4\">Real estate in Kano needed a better way</h2><p class=\"text-gray-600 leading-relaxed mb-4\">Finding a home in Kano should not be a gamble. Too many people waste time and money on unreliable agents, fake listings, and wasted trips. We built MBPP to fix that.</p><p class=\"text-gray-600 leading-relaxed mb-4\">Our platform connects you with verified agents who know the neighborhoods. Every listing is checked. Every agent is vetted. Every transaction is tracked.</p><p class=\"text-gray-600 leading-relaxed\">Whether you are renting a flat in Kano Municipal, buying land in Tarauni, or looking for commercial space in Fagge, MBPP makes it easy.</p></div><div class=\"rounded-lg overflow-hidden h-80 \"><img src=\"https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=600&amp;h=400&amp;fit=crop\" alt=\"Luxury property in Kano\" class=\"w-full h-full object-cover\"/></div></div><div class=\"grid md:grid-cols-3 gap-6 mb-20\"><div class=\"bg-white rounded-lg border border-gray-200 p-6 text-center card-hover\"><span class=\"text-3xl mb-3 block\">🏘️</span><h3 class=\"text-sm font-semibold text-gray-900 mb-2\">Verified Properties</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Every listing is confirmed by local ambassadors who know the area. No fake listings, no wasted trips.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-6 text-center card-hover\"><span class=\"text-3xl mb-3 block\">👥</span><h3 class=\"text-sm font-semibold text-gray-900 mb-2\">Trusted Agents</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Agents are assigned by city ambassadors. Performance is tracked through our task system and commission history.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-6 text-center card-hover\"><span class=\"text-3xl mb-3 block\">💰</span><h3 class=\"text-sm font-semibold text-gray-900 mb-2\">Transparent Pricing</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Clear rent tiers with no hidden fees. Commission splits are visible to all parties — agents, ambassadors, and clients.</p></div></div><div class=\"mb-20\"><div class=\"text-center mb-10\"><span class=\"text-xs font-medium text-[var(--color-primary)] uppercase tracking-wider\">Our Team</span><h2 class=\"text-2xl font-bold text-gray-900 mt-1\">Meet the People Behind MBPP</h2></div><div class=\"grid md:grid-cols-4 gap-4\"><div class=\"bg-white rounded-lg border border-gray-200 p-5 text-center\"><div class=\"w-14 h-14 rounded-full bg-[var(--color-primary)] flex items-center justify-center mx-auto mb-3\"><span class=\"text-white font-bold text-sm\">DK</span></div><h3 class=\"text-sm font-semibold text-gray-900\">Dr. Khalid Suleiman</h3><p class=\"text-xs text-[var(--color-primary)] font-medium mb-2\">CEO &amp; Founder</p><p class=\"text-xs text-gray-500 leading-relaxed\">Real estate professional with 15 years of experience in Northern Nigeria. Founded MBPP to bring transparency to the market.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-5 text-center\"><div class=\"w-14 h-14 rounded-full bg-[var(--color-primary)] flex items-center justify-center mx-auto mb-3\"><span class=\"text-white font-bold text-sm\">HB</span></div><h3 class=\"text-sm font-semibold text-gray-900\">Hadiza Bello</h3><p class=\"text-xs text-[var(--color-primary)] font-medium mb-2\">Head of Operations</p><p class=\"text-xs text-gray-500 leading-relaxed\">Oversees city operations across Kano. Ensures every listing meets our quality standards before publication.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-5 text-center\"><div class=\"w-14 h-14 rounded-full bg-[var(--color-primary)] flex items-center justify-center mx-auto mb-3\"><span class=\"text-white font-bold text-sm\">AB</span></div><h3 class=\"text-sm font-semibold text-gray-900\">Aisha Bello</h3><p class=\"text-xs text-[var(--color-primary)] font-medium mb-2\">Ambassador, Kano Municipal</p><p class=\"text-xs text-gray-500 leading-relaxed\">Manages the largest city district with 6 agents and 12 active listings. Expert in residential properties.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-5 text-center\"><div class=\"w-14 h-14 rounded-full bg-[var(--color-primary)] flex items-center justify-center mx-auto mb-3\"><span class=\"text-white font-bold text-sm\">MI</span></div><h3 class=\"text-sm font-semibold text-gray-900\">Musa Ibrahim</h3><p class=\"text-xs text-[var(--color-primary)] font-medium mb-2\">Ambassador, Fagge</p><p class=\"text-xs text-gray-500 leading-relaxed\">Specializes in commercial properties and industrial spaces. 8 years in Fagge real estate.</p></div></div></div><div class=\"text-center bg-gray-50 rounded-3xl p-12 border border-gray-100\"><h2 class=\"text-2xl font-bold text-gray-900 mb-3\">Our Mission</h2><p class=\"text-gray-500 max-w-2xl mx-auto mb-8 text-sm leading-relaxed\">To transform real estate in Northern Nigeria through technology, transparency, and local expertise. We believe everyone deserves a fair path to a home they love, and every agent deserves a platform that respects their work.</p><a class=\"inline-flex items-center px-6 py-3 bg-[var(--color-primary)] text-white rounded-lg text-sm font-medium hover:bg-[var(--color-primary-light)] transition-all shadow-lg shadow-[var(--color-primary)]/20\" href=\"/contact\">Get in Touch</a></div></section></div><!--$--><