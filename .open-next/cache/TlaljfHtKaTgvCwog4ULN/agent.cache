{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/agent/layout,_N_T_/agent/page,_N_T_/agent"},"segmentPaths":["/_tree","/_full","/agent/__PAGE__","/agent","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable h-full antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.09zddjkbdep5a.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.09~u27dqhyhd6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0ofl9qkfdlw0u.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/15pjn.n4_q6le.js\"/><script src=\"/_next/static/chunks/0pqt~8bl3ukh4.js\" async=\"\"></script><script src=\"/_next/static/chunks/07lhk_q6pmm3r.js\" async=\"\"></script><script src=\"/_next/static/chunks/0c7h~x4_chf35.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-0kemc0e062jzz.js\" async=\"\"></script><script src=\"/_next/static/chunks/06ihi7n2bbsbz.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0~gk5zxskdmgj.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>MBPP — Real Estate in Kano</title><meta name=\"description\" content=\"Find properties for rent and sale in Kano. MBPP connects you with verified listings across Kano Municipal, Fagge, Tarauni, and Nassarawa.\"/><link rel=\"manifest\" href=\"/manifest.webmanifest\"/><meta name=\"theme-color\" content=\"#0D6B3D\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"h-screen overflow-hidden\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"flex h-full\"><div class=\"flex-1 flex flex-col min-w-0\"><main class=\"flex-1 overflow-y-auto pb-16 lg:pb-0\"><div class=\"flex-1\"><section class=\"relative bg-[var(--color-primary)] py-20 px-4 overflow-hidden\"><div class=\"absolute inset-0 bg-[url(&#x27;https://images.unsplash.com/photo-1556761175-b413da4baf72?w=1200&amp;h=600&amp;fit=crop&#x27;)] bg-cover bg-center opacity-10\"></div><div class=\"relative max-w-3xl mx-auto text-center\"><span class=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/10 text-white/90 text-xs font-medium mb-6\">Manage Rentals</span><h1 class=\"text-4xl md:text-5xl font-bold text-white leading-tight\">Your Properties, <span class=\"text-[var(--color-accent)]\">One Dashboard</span></h1><p class=\"mt-4 text-lg text-white/70 max-w-2xl mx-auto\">Manage all your rental properties from a single place. Track payments, communicate with tenants, and handle agreements.</p></div></section><div class=\"max-w-5xl mx-auto px-4 py-16\"><div class=\"grid sm:grid-cols-2 gap-5 mb-16\"><div class=\"bg-white rounded-lg border border-gray-200 p-6\"><span class=\"text-2xl mb-3 block\">📊</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Track Rent Payments</h3><p class=\"text-xs text-gray-500 leading-relaxed\">See who has paid and who hasn&#x27;t. Get reminders for upcoming and overdue rent.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-6\"><span class=\"text-2xl mb-3 block\">🔑</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Tenant Management</h3><p class=\"text-xs text-gray-500 leading-relaxed\">View tenant profiles, lease terms, and contact information in one place.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-6\"><span class=\"text-2xl mb-3 block\">📝</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Digital Agreements</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Create and manage tenancy agreements with e-signatures. No paper needed.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-6\"><span class=\"text-2xl mb-3 block\">🔔</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Maintenance Requests</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Tenants can send maintenance requests. Track progress and assign contractors.</p></div></div><div class=\"bg-gray-50 rounded-lg border border-gray-200 p-8 text-center\"><h2 class=\"text-lg font-bold text-gray-900 mb-2\">Sign In to Access Your Dashboard</h2><p class=\"text-sm text-gray-500 max-w-md mx-auto mb-6\">Already have an account? Sign in to view your rental properties, track payments, and manage tenants.</p><div class=\"flex items-center justify-center gap-4\"><a href=\"/login\"><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed px-7 py-3.5 text-base gap-2 bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-light)] focus:ring-[var(--color-primary)] \">Sign In</button></a><a href=\"/register\"><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed px-7 py-3.5 text-base gap-2 border border-[var(--color-primary)] text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 focus:ring-[var(--color-primary)] \">Create Account</button></a></div></div></div></div><!--$--><!--/$--></main></div></div><script src=\"/_next/static/chunks/15pjn.n4_q6le.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[98867,[\\\"/_next/static/chunks/06ihi7n