.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9\"></path></svg>Demo<svg class=\"w-3 h-3 ml-auto transition-transform duration-150 \" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19 9l-7 7-7-7\"></path></svg></button></div><button class=\"flex items-center justify-center w-full py-1.5 text-gray-400 hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 rounded-lg transition-all duration-150 group\" title=\"Collapse\"><svg class=\"w-4 h-4 transition-all duration-300 group-hover:-translate-x-0.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M15.75 19.5L8.25 12l7.5-7.5\"></path></svg></button></div></aside><div class=\"flex-1 flex flex-col min-w-0\"><div class=\"hidden lg:flex items-center h-12 px-6 bg-white border-b border-gray-200\"><nav class=\"flex items-center gap-2 flex-1\"><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/?type=buy\">Buy</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/?type=rent\">Rent</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/sell\">Sell</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/agent\">Manage Rentals</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/list-property\">Advertise</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/about\">About</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/contact\">Contact</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/help\">Get Help</a></nav><div class=\"flex items-center gap-2\"><a class=\"text-xs text-white bg-[var(--color-primary)] px-3 py-1.5 rounded-md hover:bg-[var(--color-primary-light)] transition-colors\" href=\"/login\">Sign In</a></div></div><main class=\"flex-1 overflow-y-auto pb-16 lg:pb-0\"><div class=\"flex-1\"><section class=\"relative bg-[var(--color-primary)] py-20 px-4 overflow-hidden\"><div class=\"absolute inset-0 bg-[url(&#x27;https://images.unsplash.com/photo-1521791136064-7986c2920216?w=1200&amp;h=600&amp;fit=crop&#x27;)] bg-cover bg-center opacity-10\"></div><div class=\"relative max-w-3xl mx-auto text-center\"><span class=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/10 text-white/90 text-xs font-medium mb-6\">Careers</span><h1 class=\"text-4xl md:text-5xl font-bold text-white leading-tight\">Join the Team That Is <span class=\"text-[var(--color-accent)]\">Transforming Kano Real Estate</span></h1><p class=\"mt-4 text-lg text-white/70 max-w-2xl mx-auto\">Help us build the future of property in Northern Nigeria.</p></div></section><div class=\"max-w-5xl mx-auto px-4 py-16\"><div class=\"grid md:grid-cols-4 gap-6 mb-20\"><div class=\"bg-white rounded-lg border border-gray-200 p-5 text-center\"><span class=\"text-2xl mb-3 block\">🎯</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Local First</h3><p class=\"text-xs text-gray-500 leading-relaxed\">We build for Kano. Every decision starts with understanding our users and their neighbourhoods.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-5 text-center\"><span class=\"text-2xl mb-3 block\">🔍</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Transparency</h3><p class=\"text-xs text-gray-500 leading-relaxed\">No hidden fees, no fake listings, no surprises. What you see is what you get.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-5 text-center\"><span class=\"text-2xl mb-3 block\">📈</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Growth</h3><p class=\"text-xs text-gray-500 leading-relaxed\">We invest in our people. Agents get training, ambassadors get leadership development, and everyone shares in the success.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-5 text-center\"><span class=\"text-2xl mb-3 block\">🤝</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Community</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Real estate is about people. We foster trust between tenants, landlords, agents, and the platform.</p></div></div><div class=\"mb-12\"><h2 class=\"text-2xl font-bold text-gray-900 mb-1\">Open Positions</h2><p class=\"text-sm text-gray-500 mb-8\">6<!-- --> roles available. We review applications on a rolling basis.</p><div class=\"grid md:grid-cols-2 gap-4\"><div class=\"bg-white rounded-lg border border-gray-200 p-5 hover:shadow-sm transition-shadow\"><div class=\"flex items-start justify-between mb-2\"><h3 class=\"text-sm font-semibold text-gray-900\">Field Agent — Kano Municipal</h3><span class=\"text-[10px] font-medium text-[var(--color-primary)] bg-[var(--color-primary)]/5 px-2 py-0.5 rounded-full\">Full-time</span></div><p class=\"text-xs text-gray-400 mb-2\">Kano Municipal</p><p class=\"text-xs text-gray-500 leading-relaxed mb-4\">Show properties to prospective tenants, complete tasks assigned by the ambassador, and close rental agreements. Commission-based with monthly minimum guarantee.</p><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed px-3.5 py-2 text-xs gap-1.5 bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-light)] focus:ring-[var(--color-primary)] \">Apply Now</button></div><div class=\"bg-white rounded-lg border border-gray-200 p-5 hover:shadow-sm transition-shadow\"><div class=\"flex items-start justify-between mb-2\"><h3 class=\"text-sm font-semibold text-gray-900\">Field Agent — Fagge</h3><span class=\"text-[10px] font-medium text-[var(--color-primary)] bg-[var(--color-primary)]/5 px-2 py-0.5 rounded-full\">Full-time</span></div><p class=\"text-xs text-gray-400 mb-2\">Fagge</p><p class=\"text-xs text-gray-500 leading-relaxed mb-4\">Cover commercial and residential properties in Fagge district. Must know the local market well and have reliable transportation.</p><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed px-3.5 py-2 text-xs gap-1.5 bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-light)] focus:ring-[var(--color-primary)] \">Apply Now</button></div><div class=\"bg-white rounded-lg border border-gray-200 p-5 hover:shadow-sm transition-shadow\"><div class=\"flex items-start justify-between mb-2\"><h3 class=\"text-sm font-semibold text-gray-900\">Ambassador — Tarauni</h3><span class=\"text-[10px] font-medium text-[var(--color-primary)] bg-[var(--color-primary)]/5 px-2 py-0.5 rounded-full\">Full-time</span></div><p class=\"text-xs text-gray-400 mb-2\">Tarauni</p><p class=\"text-xs text-gray-500 leading-relaxed mb-4\">Manage all operations in Tarauni district — onboard agents, verify listings, assign tasks, and grow market share. Previous real estate experience required.</p><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed px-3.5 py-2 text-xs gap-1.5 bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-light)] focus:ring-[var(--color-primary)] \">Apply Now</button></div><div class=\"bg-white rounded-lg border border-gray-200 p-5 hover:shadow-sm transition-shadow\"><div class=\"flex items-start justify-between mb-2\"><h3 class=\"text-sm font-semibold text-gray-900\">Ambassador — Nassarawa</h3><span class=\"text-[10px] font-medium text-[var(--color-primary)] bg-[var(--color-primary)]/5 px-2 py-0.5 rounded-full\">Full-time</span></div><p class=\"text-xs text-gray-400 mb-2\">Nassarawa</p><p class=\"text-xs text-gray-500 leading-relaxed mb-4\">Lead the Nassarawa expansion. Hire and train local agents, establish relationships with landlords, and hit growth targets.</p><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed px-3.5 py-2 text-xs gap-1.5 bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-light)] focus:ring-[var(--color-primary)] \">Apply Now</button></div><div class=\"bg-white rounded-lg border border-gray-200 p-5 hover:shadow-sm transition-shadow\"><div class=\"flex items-start justify-between mb-2\"><h3 class=\"text-sm font-semibold text-gray-900\">Software Engineer (Frontend)</h3><span class=\"text-[10px] font-medium text-[var(--color-primary)] bg-[var(--color-primary)]/5 px-2 py-0.5 rounded-full\">Remote</span></div><p class=\"text-xs text-gray-400 mb-2\">Remote / Kano</p><p class=\"text-xs text-gray-500 leading-relaxed mb-4\">Build and maintain our Next.js frontend. Strong React skills and eye for UI/UX required. Experience with TypeScript and Tailwind CSS preferred.</p><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed px-3.5 py-2 text-xs gap-1.5 bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-light)] focus:ring-[var(--color-primary)] \">Apply Now</button></div><div class=\"bg-white rounded-lg border border-gray-200 p-5 hover:shadow-sm transition-shadow\"><div class=\"flex items-start justify-between mb-2\"><h3 class=\"text-sm font-semibold text-gray-900\">Customer Support Lead</h3><span class=\"text-[10px] font-medium text-[var(--color-primary)] bg-[var(--color-primary)]/5 px-2 py-0.5 rounded-full\">Full-time</span></div><p class=\"text-xs text-gray-400 mb-2\">Kano Municipal</p><p class=\"text-xs text-gray-500 leading-relaxed mb-4\">Manage our support team, handle escalations, and ensure every user gets prompt help. Experience in property or fintech support is a plus.</p><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed px-3.5 py-2 text-xs gap-1.5 bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-light)] focus:ring-[var(--color-primary)] \">Apply Now</button></div></div></div><div class=\"bg-gray-50 rounded-lg border border-gray-200 p-8 text-center\"><h2 class=\"text-lg font-bold text-gray-900 mb-2\">Do Not See a Role That Fits?</h2><p class=\"text-sm text-gray-500 max-w-md mx-auto mb-6\">We are always looking for talented people. Send us your CV and we will keep you in mind for future openings.</p><a href=\"/contact\"><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed px-5 py-2.5 text-sm gap-2 border border-[var(--color-primary)] text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 focus:ring-[var(--color-primary)] \">Send Your CV</button></a></div></div></div><!--$--><!--/$--></main></div></div><nav class=\"lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-white border-t border-gray-200 pb-safe\"><div class=\"flex items-center justify-around h-14\"><a class=\"relative flex flex-col items-center 