unded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/contact\">Contact</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/help\">Get Help</a></nav><div class=\"flex items-center gap-2\"><a class=\"text-xs text-white bg-[var(--color-primary)] px-3 py-1.5 rounded-md hover:bg-[var(--color-primary-light)] transition-colors\" href=\"/login\">Sign In</a></div></div><main class=\"flex-1 overflow-y-auto pb-16 lg:pb-0\"><div class=\"flex-1\"><section class=\"relative bg-[var(--color-primary)] py-20 px-4 overflow-hidden\"><div class=\"absolute inset-0 bg-[url(&#x27;https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=1200&amp;h=600&amp;fit=crop&#x27;)] bg-cover bg-center opacity-10\"></div><div class=\"relative max-w-3xl mx-auto text-center\"><span class=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/10 text-white/90 text-xs font-medium mb-6\">List Your Property</span><h1 class=\"text-4xl md:text-5xl font-bold text-white leading-tight\">Sell or Rent with <span class=\"text-[var(--color-accent)]\">MBPP</span></h1><p class=\"mt-4 text-lg text-white/70 max-w-2xl mx-auto\">Kano&#x27;s fastest-growing real estate marketplace. List your property and reach thousands of serious buyers and tenants.</p></div></section><div class=\"max-w-5xl mx-auto px-4 py-16\"><div class=\"text-center mb-12\"><span class=\"text-xs font-medium text-[var(--color-primary)] uppercase tracking-wider\">Why List With Us</span><h2 class=\"text-2xl font-bold text-gray-900 mt-2\">Everything You Need to Sell or Rent</h2></div><div class=\"grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-20\"><div class=\"bg-white rounded-lg border border-gray-200 p-5\"><span class=\"text-2xl mb-3 block\">📸</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Professional Photos</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Our ambassadors visit your property to take high-quality photos that attract serious tenants and buyers.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-5\"><span class=\"text-2xl mb-3 block\">📢</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Wide Exposure</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Your listing reaches thousands of monthly visitors on MBPP and is shared across our social media channels.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-5\"><span class=\"text-2xl mb-3 block\">✅</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Tenant Screening</h3><p class=\"text-xs text-gray-500 leading-relaxed\">We pre-screen applicants so you only deal with qualified, serious tenants ready to move in.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-5\"><span class=\"text-2xl mb-3 block\">📝</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Digital Agreements</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Generate legally compliant tenancy agreements with e-signatures. No paperwork, no delays.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-5\"><span class=\"text-2xl mb-3 block\">💰</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Secure Payments</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Rent payments and holding deposits are processed securely through Paystack with full transaction records.</p></div><div class=\"bg-white rounded-lg border border-gray-200 p-5\"><span class=\"text-2xl mb-3 block\">📊</span><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Performance Dashboard</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Track views, inquiries, and applications for your property in real time from your owner dashboard.</p></div></div><div class=\"mb-20\"><div class=\"text-center mb-10\"><span class=\"text-xs font-medium text-[var(--color-primary)] uppercase tracking-wider\">How It Works</span><h2 class=\"text-2xl font-bold text-gray-900 mt-2\">Get Your Property Listed in 5 Steps</h2></div><div class=\"grid md:grid-cols-5 gap-4\"><div class=\"text-center\"><div class=\"w-12 h-12 rounded-full bg-[var(--color-primary)] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3\">1</div><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Contact Us</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Reach out through the form below or call us. We will discuss your property and pricing.</p></div><div class=\"text-center\"><div class=\"w-12 h-12 rounded-full bg-[var(--color-primary)] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3\">2</div><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Property Visit</h3><p class=\"text-xs text-gray-500 leading-relaxed\">An MBPP ambassador visits your property to take photos, verify details, and assess the listing.</p></div><div class=\"text-center\"><div class=\"w-12 h-12 rounded-full bg-[var(--color-primary)] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3\">3</div><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Listing Goes Live</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Your property is published on MBPP with photos, description, and pricing. You will get a link to share.</p></div><div class=\"text-center\"><div class=\"w-12 h-12 rounded-full bg-[var(--color-primary)] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3\">4</div><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Receive Inquiries</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Interested tenants and buyers send inquiries. You can respond directly through our messaging system.</p></div><div class=\"text-center\"><div class=\"w-12 h-12 rounded-full bg-[var(--color-primary)] text-white text-lg font-bold flex items-center justify-center mx-auto mb-3\">5</div><h3 class=\"text-sm font-semibold text-gray-900 mb-1\">Close the Deal</h3><p class=\"text-xs text-gray-500 leading-relaxed\">Once a tenant or buyer is confirmed, we help with the agreement and payment processing.</p></div></div></div><div class=\"bg-gray-50 rounded-lg border border-gray-200 p-8 text-center\"><h2 class=\"text-xl font-bold text-gray-900 mb-2\">Ready to Get Started?</h2><p class=\"text-sm text-gray-500 max-w-lg mx-auto mb-6\">Fill out the form below or call us directly. We will get back to you within 24 hours.</p><div class=\"flex items-center justify-center gap-4 flex-wrap\"><a href=\"/contact\"><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed px-7 py-3.5 text-base gap-2 bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-light)] focus:ring-[var(--color-primary)] \">Contact Us</button></a><a href=\"https://wa.me/2348000000000\" target=\"_blank\" rel=\"noopener noreferrer\"><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed px-7 py-3.5 text-base gap-2 border border-[var(--color-primary)] text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 focus:ring-[var(--color-primary)] \">Chat on WhatsApp</button></a></div></div></div></div><!--$--><!--/$--></main></div></div><nav class=\"lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-white border-t border-gray-200 pb-safe\"><div class=\"flex items-center justify-around h-14\"><a class=\"relative flex flex-col items-center justify-center gap-0.5 h-full px-3 transition-colors duration-150 active:scale-95 text-gray-400\" href=\"/\"><svg class=\"w-5 h-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z\"></path></svg><span class=\"text-[10px] f