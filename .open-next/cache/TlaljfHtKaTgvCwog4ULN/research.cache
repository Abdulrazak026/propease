t-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/contact\">Contact</a><a class=\"text-sm font-medium px-3 py-1.5 rounded-md transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50\" href=\"/help\">Get Help</a></nav><div class=\"flex items-center gap-2\"><a class=\"text-xs text-white bg-[var(--color-primary)] px-3 py-1.5 rounded-md hover:bg-[var(--color-primary-light)] transition-colors\" href=\"/login\">Sign In</a></div></div><main class=\"flex-1 overflow-y-auto pb-16 lg:pb-0\"><div class=\"flex-1\"><section class=\"bg-gray-50 py-16 px-4 border-b border-gray-200\"><div class=\"max-w-4xl mx-auto text-center\"><span class=\"text-xs font-medium text-[var(--color-primary)] uppercase tracking-wider\">Research</span><h1 class=\"text-3xl font-bold text-gray-900 mt-2 mb-3\">Market Research</h1><p class=\"text-gray-500 max-w-lg mx-auto\">Data-driven insights into the Kano real estate market — powered by MBPP transaction data and local surveys.</p></div></section><div class=\"max-w-5xl mx-auto px-4 py-12\"><div class=\"grid gap-6\"><div class=\"bg-white rounded-lg border border-gray-200 p-6 hover:shadow-sm transition-shadow\"><div class=\"flex items-start justify-between mb-3\"><h2 class=\"text-base font-semibold text-gray-900\">Kano Residential Market Report — Q1 2026</h2><span class=\"text-xs text-gray-400 shrink-0 ml-4\">April 2026</span></div><p class=\"text-sm text-gray-600 leading-relaxed mb-4\">Average rents rose 12% year-on-year across Kano Municipal. Tarauni and Nassarawa saw the highest demand for 2-bedroom flats.</p><div class=\"flex flex-wrap gap-2\"><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">12% YoY rent increase</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">340 active listings</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">4.2 avg days on market</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">₦850K avg annual rent</span></div></div><div class=\"bg-white rounded-lg border border-gray-200 p-6 hover:shadow-sm transition-shadow\"><div class=\"flex items-start justify-between mb-3\"><h2 class=\"text-base font-semibold text-gray-900\">Northern Nigeria Real Estate Outlook 2026</h2><span class=\"text-xs text-gray-400 shrink-0 ml-4\">January 2026</span></div><p class=\"text-sm text-gray-600 leading-relaxed mb-4\">Comprehensive analysis of property trends across Kano, Kaduna, and Katsina states including urban migration patterns and infrastructure impact.</p><div class=\"flex flex-wrap gap-2\"><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">6 states covered</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">2,100+ data points</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">15 city districts</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">3-year forecast</span></div></div><div class=\"bg-white rounded-lg border border-gray-200 p-6 hover:shadow-sm transition-shadow\"><div class=\"flex items-start justify-between mb-3\"><h2 class=\"text-base font-semibold text-gray-900\">Rental Affordability Index — Kano State</h2><span class=\"text-xs text-gray-400 shrink-0 ml-4\">March 2026</span></div><p class=\"text-sm text-gray-600 leading-relaxed mb-4\">How rent-to-income ratios vary across Kano&#x27;s eight local government areas. Fagge remains the most affordable district for young professionals.</p><div class=\"flex flex-wrap gap-2\"><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">28% avg rent-to-income</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">₦180K median salary</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">8 LGAs analysed</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">5 property types</span></div></div><div class=\"bg-white rounded-lg border border-gray-200 p-6 hover:shadow-sm transition-shadow\"><div class=\"flex items-start justify-between mb-3\"><h2 class=\"text-base font-semibold text-gray-900\">Commercial Property Trends in Kano</h2><span class=\"text-xs text-gray-400 shrink-0 ml-4\">February 2026</span></div><p class=\"text-sm text-gray-600 leading-relaxed mb-4\">Demand for retail and office space is shifting toward the new Kano City Centre development. Industrial space in Fagge remains undersupplied.</p><div class=\"flex flex-wrap gap-2\"><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">22% vacancy rate</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">₦2.1M avg annual rent</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">3 new developments</span><span class=\"px-3 py-1 bg-[var(--color-primary)]/5 text-[var(--color-primary)] text-xs font-medium rounded-full\">+8% commercial growth</span></div></div></div><div class=\"mt-12 bg-gray-50 rounded-lg border border-gray-200 p-8 text-center\"><h2 class=\"text-lg font-bold text-gray-900 mb-2\">Request Custom Research</h2><p class=\"text-sm text-gray-500 max-w-md mx-auto mb-6\">Need data on a specific neighbourhood, property type, or price range? Our team can prepare a tailored report.</p><a class=\"inline-flex items-center px-6 py-3 bg-[var(--color-primary)] text-white rounded-lg text-sm font-medium hover:bg-[var(--color-primary-light)] transition-all\" href=\"/contact\">Request Report</a></div></div></div><!--$--><!--/$--></main></div></div><nav class=\"lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-white border-t border-gray-200 pb-safe\"><div class=\"flex items-center justify-around h-14\"><a class=\"relative flex flex-col items-center justify-center gap-0.5 h-full px-3 transition-colors duration-150 active:scale-95 text-gray-400\" href=\"/\"><svg class=\"w-5 h-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z\"></path></svg><span class=\"text-[10px] font-medium \">Browse</span></a><a class=\"relative flex flex-col items-center justify-center gap-0.5 h-full px-3 transition-colors duration-150 active:scale-95 text-gray-400\" href=\"/saved\"><svg class=\"w-5 h-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z\"></path></svg><span class=\"text-[10px] font-medium \">Saved</span></a><a class=\"relative flex flex-col items-center justify-center gap-0.5 h-full px-3 transition-colors duration-150 active:scale-95 text-gray-400\" href=\"/messages\"><svg class=\"w-5 h-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.525C3.373 3.74