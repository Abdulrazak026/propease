generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  head
  ambassador
  agent
}

enum ListingType {
  sale
  rent
}

enum RentTier {
  normal
  damages
  full
}

enum ListingStatus {
  available
  reserved
  taken
}

enum ListingCategory {
  portfolio
  partnership
}

enum PropertyType {
  house
  land
  flat
  commercial
  other
}

enum TaskStatus {
  open
  in_progress
  fulfilled
  closed
}

enum TaskSource {
  internal
  client_request
}

enum TransactionType {
  top_up
  payment
  commission_payout
  withdrawal
}

enum TransactionMethod {
  wallet
  card
  transfer
}

enum TransactionStatus {
  pending
  completed
  failed
}

enum InquiryStatus {
  new
  read
  responded
}

enum ReservationStatus {
  pending
  confirmed
  expired
}

enum CustomOrderStatus {
  pending
  routed
  fulfilled
}

enum WithdrawalStatus {
  pending
  approved
  paid
  rejected
}

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  password       String
  role           UserRole
  city           String?
  walletBalance  Int       @default(0)
  canCreateTasks Boolean   @default(false)
  canCloseDeals  Boolean   @default(false)
  isApproved     Boolean   @default(false)
  isVerified     Boolean   @default(false)
  verifiedAt     DateTime?
  verificationDoc String?
  whatsapp       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  ambassadorId  String?
  ambassador    User?     @relation("AmbassadorAgents", fields: [ambassadorId], references: [id])
  agents        User[]    @relation("AmbassadorAgents")

  cities        UserCity[]
  listings      Listing[]         @relation("PostedListings")
  assignedListings Listing[]      @relation("AssignedListings")
  createdTasks  Task[]            @relation("CreatedTasks")
  assignedTasks Task[]            @relation("AssignedTasks")
  commissionsAsAmbassador Commission[] @relation("AmbassadorCommissions")
  commissionsAsAgent      Commission[] @relation("AgentCommissions")
  tenantApplications  TenantApplication[]
  assignedInquiries   Inquiry[]
  transactions  Transaction[]
  reservations  Reservation[]
  withdrawals   Withdrawal[]
  comments      TaskComment[]
  auditLogs     AuditLog[]
  tokens        RefreshToken[]
  rentAgreementsAsTenant  RentAgreement[] @relation("RentAgreementTenant")
  rentAgreementsAsAgent   RentAgreement[] @relation("RentAgreementAgent")
  priceChanges        PriceChange[]
  savedSearches       SavedSearch[]
  writtenReviews      Review[]
  agentReviews        Review[]           @relation("AgentReviews")
  conversationParticipants ConversationParticipant[]
  sentMessages        Message[]
  notifications       Notification[]

  @@index([email])
  @@index([role])
  @@index([ambassadorId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model City {
  id        String     @id @default(uuid())
  name      String
  state     String     @default("Kano")
  cities    UserCity[]

  @@unique([name, state])
}

model UserCity {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cityId String
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@id([userId, cityId])
}

model Listing {
  id               String         @id @default(uuid())
  title            String
  description      String
  propertyType     PropertyType
  listingType      ListingType
  rentTier         RentTier?
  annualRent       Int?
  damageDeposit    Int?
  maintenanceCharge Int?
  salePrice        Int?
  status           ListingStatus  @default(available)
  category         ListingCategory
  partnerCompany   String?
  lat              Float?
  lng              Float?
  address          String
  city             String
  bedrooms         Int?
  bathrooms        Int?
  sqft             Int?
  price            Int            @default(0)
  features         String[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  postedById    String
  postedBy      User     @relation("PostedListings", fields: [postedById], references: [id])

  assignedAgentId String?
  assignedAgent   User?   @relation("AssignedListings", fields: [assignedAgentId], references: [id])

  photos       ListingPhoto[]
  inquiries    Inquiry[]
  reservations Reservation[]
  tenantApplications TenantApplication[]
  rentAgreements     RentAgreement[]
  priceChanges       PriceChange[]
  reviews            Review[]
  conversations      Conversation[]

  @@index([status])
  @@index([city])
  @@index([propertyType])
  @@index([listingType])
  @@index([postedById])
  @@index([assignedAgentId])
}

model ListingPhoto {
  id        String  @id @default(uuid())
  url       String
  alt       String?
  order     Int     @default(0)
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Task {
  id              String      @id @default(uuid())
  title           String
  description     String
  propertyType    PropertyType
  area            String
  budget          Int
  deadline        DateTime
  notes           String?
  status          TaskStatus  @default(open)
  source          TaskSource  @default(internal)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  createdById String
  createdBy   User   @relation("CreatedTasks", fields: [createdById], references: [id])

  assignedToId String
  assignedTo   User   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  submittedListingId String?

  comments   TaskComment[]
  customOrder CustomOrder?

  @@index([status])
  @@index([assignedToId])
  @@index([createdById])
}

model TaskComment {
  id        String   @id @default(uuid())
  text      String
  createdAt DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model CommissionRate {
  id        String @id @default(uuid())
  dealType  String @unique
  totalRate Float
  ambassadorRate Float
  agentRate Float
  updatedAt DateTime @updatedAt
}

model Commission {
  id             String   @id @default(uuid())
  dealId         String   @unique
  dealTitle      String
  dealType       String
  totalAmount    Int
  ambassadorRate Float
  ambassadorCut  Int
  agentRate      Float
  agentCut       Int
  companyCut     Int
  paidAt         DateTime @default(now())

  ambassadorId String
  ambassador   User @relation("AmbassadorCommissions", fields: [ambassadorId], references: [id])

  agentId String
  agent   User @relation("AgentCommissions", fields: [agentId], references: [id])

  @@index([ambassadorId])
  @@index([agentId])
}

model Transaction {
  id        String             @id @default(uuid())
  type      TransactionType
  amount    Int
  reference String             @unique
  method    TransactionMethod
  status    TransactionStatus  @default(pending)
  createdAt DateTime           @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([reference])
}

model Inquiry {
  id            String        @id @default(uuid())
  clientName    String
  clientContact String
  message       String
  status        InquiryStatus @default(new)
  createdAt     DateTime      @default(now())

  listingId      String
  listing        Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  assignedAgentId String?
  assignedAgent   User?   @relation(fields: [assignedAgentId], references: [id])

  @@index([listingId])
  @@index([assignedAgentId])
}

model Reservation {
  id             String            @id @default(uuid())
  clientName     String
  holdingDeposit Int
  status         ReservationStatus @default(pending)
  expiresAt      DateTime
  createdAt      DateTime          @default(now())

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([listingId])
}

enum ApplicationStatus {
  draft
  submitted
  under_review
  approved
  rejected
}

model TenantApplication {
  id            String             @id @default(uuid())
  status        ApplicationStatus  @default(draft)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // Step 1: Personal Info
  fullName      String
  email         String
  phone         String
  dateOfBirth   String?

  // Step 2: Employment
  employmentStatus String?
  employer       String?
  jobTitle       String?
  workAddress    String?

  // Step 3: Income
  monthlyIncome  Int?
  incomeCurrency String?            @default("NGN")
  incomeDocument String?

  // Step 4: ID Upload
  idType        String?
  idNumber      String?
  idDocument    String?

  // Step 5: References
  refName       String?
  refPhone      String?
  refEmail      String?
  refRelation   String?

  // Step 6: Next of Kin
  nokName       String?
  nokPhone      String?
  nokEmail      String?
  nokRelation   String?

  // Notes from agent
  agentNotes    String?

  listingId     String?
  listing       Listing?  @relation(fields: [listingId], references: [id])
  assignedAgentId String?
  assignedAgent   User?     @relation(fields: [assignedAgentId], references: [id])
  rentAgreements  RentAgreement[]

  @@index([status])
  @@index([email])
  @@index([assignedAgentId])
}

model CustomOrder {
  id            String           @id @default(uuid())
  propertyType  PropertyType
  area          String
  budget        Int
  notes         String?
  clientName    String
  clientContact String
  status        CustomOrderStatus @default(pending)
  createdAt     DateTime         @default(now())

  taskId String? @unique
  task   Task?   @relation(fields: [taskId], references: [id])
}

model Withdrawal {
  id          String            @id @default(uuid())
  amount      Int
  bankName    String
  accountNumber String
  accountName String
  status      WithdrawalStatus  @default(pending)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

enum AgreementStatus {
  draft
  pending_landlord
  pending_tenant
  completed
  expired
  terminated
}

model RentAgreement {
  id                     String          @id @default(uuid())
  status                 AgreementStatus @default(draft)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  // Tenant info (denormalized from application)
  tenantName             String
  tenantEmail            String
  tenantPhone            String
  tenantSignature        String?
  tenantSignedAt         DateTime?

  // Landlord/Agent info
  landlordName           String
  landlordSignature      String?
  landlordSignedAt       DateTime?

  // Property info (from listing)
  propertyTitle          String
  propertyAddress        String
  propertyCity           String
  annualRent             Int
  damageDeposit          Int?
  serviceCharge          Int?

  // Agreement terms
  startDate              DateTime
  endDate                DateTime
  rentDueDay             Int              @default(1)
  noticePeriodDays       Int              @default(30)
  renewalType            String           @default("yearly")

  // Document reference
  documentUrl            String?

  listingId             String?
  listing               Listing?  @relation(fields: [listingId], references: [id])
  tenantId              String?
  tenant                User?     @relation("RentAgreementTenant", fields: [tenantId], references: [id])
  agentId               String?
  agent                 User?     @relation("RentAgreementAgent", fields: [agentId], references: [id])
  applicationId         String?
  application           TenantApplication? @relation(fields: [applicationId], references: [id])

  @@index([status])
  @@index([tenantId])
  @@index([agentId])
}

enum ReviewStatus {
  pending
  approved
  hidden
}

model PriceChange {
  id        String   @id @default(uuid())
  oldPrice  Int
  newPrice  Int
  reason    String?
  createdAt DateTime @default(now())

  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  changedById String?
  changedBy   User?    @relation(fields: [changedById], references: [id])

  @@index([listingId])
  @@index([createdAt])
}

model SavedSearch {
  id           String   @id @default(uuid())
  name         String?
  searchParams Json
  notifyEmail  Boolean  @default(true)
  notifySms    Boolean  @default(false)
  notifyPush   Boolean  @default(false)
  lastNotifiedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Review {
  id        String       @id @default(uuid())
  rating    Int
  comment   String?
  status    ReviewStatus @default(pending)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  authorId  String
  author    User         @relation(fields: [authorId], references: [id])

  agentId   String
  agent     User         @relation("AgentReviews", fields: [agentId], references: [id])

  listingId String?
  listing   Listing?     @relation(fields: [listingId], references: [id])

  @@index([agentId])
  @@index([status])
  @@index([authorId])
}

enum NotificationType {
  saved_search_match
  review_response
  agreement_signed
  application_status
  message_received
  price_change
}

model Conversation {
  id        String    @id @default(uuid())
  subject   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
  listingId    String?
  listing      Listing?  @relation(fields: [listingId], references: [id])

  @@index([updatedAt])
}

model ConversationParticipant {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
